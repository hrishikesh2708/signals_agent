# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=signals-langraph-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Logging
LOG_LEVEL=INFO

# Optional default user name for CLI invokes (Studio: set user_name in input JSON)
SIGNALS_DEFAULT_USER_NAME=

# Salesforce OAuth (required when calling SalesforceConnector.auth_url / exchange)
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_CALLBACK_URL=
SF_OAUTH_SCOPE=
SF_LOGIN_URL=https://login.salesforce.com

# HubSpot OAuth (required when calling HubSpotConnector auth/exchange)
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=
HUBSPOT_SCOPES=

# Zoho OAuth (required when calling ZohoConnector auth/exchange)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=
ZOHO_SCOPES=
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com

# PostgreSQL (FastAPI + SQLAlchemy async — use psycopg driver)
DATABASE_URL=postgresql+psycopg://signals:signals@localhost:5432/signals

# FastAPI server
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
JWT_SECRET=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:3000

# Next.js client / CopilotKit
NEXT_PUBLIC_API_URL=http://localhost:8000
